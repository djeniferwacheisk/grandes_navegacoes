config_version=5

[application]

config/name="Grandes Navegações"
config/description="Jogo educativo sobre as Grandes Navegações portuguesas"
run/main_scene="uid://bcc3bfgj1cgsr"
config/features=PackedStringArray("4.6")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SceneManager="*res://scripts/autoload/scene_manager.gd"
GlobalWind="*res://scripts/GlobalWind.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=3
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

